# LLM Configuration
# Provider: auto (default) | openai | ollama | heuristic

# Cloud LLM (OpenAI-compatible — DeepSeek, Groq, etc.)
OPENAI_API_KEY=sk-your-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Ollama local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Force provider (default: auto — uses cloud if key, else ollama if running, else heuristic)
# LLM_PROVIDER=openai